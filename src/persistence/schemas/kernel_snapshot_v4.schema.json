{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ethos-kernel.local/schemas/kernel_snapshot_v4.json",
  "title": "KernelSnapshotV1",
  "description": "Versioned kernel checkpoint (schema4). Advisory-only fields are documented per-property; they must not alter MalAbs or Bayesian final_action by themselves.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "episodes",
    "narrative_counter",
    "identity_state",
    "experience_digest",
    "forgiveness_memories",
    "forgiveness_cycle",
    "forgiveness_recent_positives",
    "weakness_type",
    "weakness_base_intensity",
    "weakness_records",
    "weakness_cycle",
    "bayesian_pruning_threshold",
    "bayesian_gray_zone_threshold",
    "bayesian_hypothesis_weights",
    "locus_alpha",
    "locus_beta",
    "locus_success_history",
    "locus_failure_history",
    "variability_seed",
    "variability_active",
    "pruned_actions",
    "dao_record_counter",
    "dao_records",
    "dao_alerts",
    "constitution_l1_drafts",
    "constitution_l2_drafts",
    "dao_proposal_counter",
    "dao_participants",
    "dao_proposals",
    "metaplan_goals",
    "somatic_marker_weights",
    "skill_learning_tickets",
    "user_model_frustration_streak",
    "user_model_premise_concern_streak",
    "user_model_last_circle",
    "user_model_turns_observed",
    "user_model_cognitive_pattern",
    "user_model_risk_band",
    "user_model_judicial_phase",
    "subjective_turn_index",
    "subjective_stimulus_ema",
    "escalation_session_strikes",
    "escalation_session_idle_turns",
    "uchi_soto_profiles",
    "migratory_body"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 4
    },
    "episodes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "narrative_counter": { "type": "integer" },
    "identity_state": {
      "type": "object",
      "description": "NarrativeIdentityState leans and episode_count."
    },
    "experience_digest": {
      "type": "string",
      "description": "Advisory: narrative continuity digest for LLM/context; not used for policy."
    },
    "forgiveness_memories": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "forgiveness_cycle": { "type": "integer" },
    "forgiveness_recent_positives": { "type": "integer" },
    "weakness_type": { "type": "string" },
    "weakness_base_intensity": {
      "oneOf": [{ "type": "number" }, { "type": "null" }]
    },
    "weakness_records": {
      "type": "array",
      "items": { "type": "object" }
    },
    "weakness_cycle": { "type": "integer" },
    "bayesian_pruning_threshold": { "type": "number" },
    "bayesian_gray_zone_threshold": { "type": "number" },
    "bayesian_hypothesis_weights": {
      "type": "array",
      "items": { "type": "number" }
    },
    "locus_alpha": { "type": "number" },
    "locus_beta": { "type": "number" },
    "locus_success_history": { "type": "integer" },
    "locus_failure_history": { "type": "integer" },
    "variability_seed": {
      "oneOf": [{ "type": "integer" }, { "type": "null" }]
    },
    "variability_active": { "type": "boolean" },
    "pruned_actions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "dao_record_counter": { "type": "integer" },
    "dao_records": {
      "type": "array",
      "description": "MockDAO audit lines (serialized AuditRecord dicts).",
      "items": {
        "type": "object",
        "required": ["id", "type", "content", "timestamp"],
        "additionalProperties": true
      }
    },
    "dao_alerts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "constitution_l1_drafts": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Advisory: L1 constitution drafts (DemocraticBuffer)."
    },
    "constitution_l2_drafts": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Advisory: L2 constitution drafts."
    },
    "dao_proposal_counter": { "type": "integer" },
    "dao_participants": {
      "type": "array",
      "items": { "type": "object" }
    },
    "dao_proposals": {
      "type": "array",
      "items": { "type": "object" }
    },
    "metaplan_goals": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Advisory: master goals for LLM/metaplan hints."
    },
    "somatic_marker_weights": {
      "type": "object",
      "additionalProperties": { "type": "number" },
      "description": "Advisory: somatic marker weights."
    },
    "skill_learning_tickets": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Advisory: skill learning ticket payloads."
    },
    "user_model_frustration_streak": { "type": "integer" },
    "user_model_premise_concern_streak": { "type": "integer" },
    "user_model_last_circle": { "type": "string" },
    "user_model_turns_observed": { "type": "integer" },
    "user_model_cognitive_pattern": {
      "type": "string",
      "description": "Advisory: user-model tone aggregate."
    },
    "user_model_risk_band": {
      "type": "string",
      "description": "Advisory: coarse risk band for hints."
    },
    "user_model_judicial_phase": {
      "type": "string",
      "description": "Advisory: judicial escalation phase hint."
    },
    "subjective_turn_index": { "type": "integer" },
    "subjective_stimulus_ema": { "type": "number" },
    "escalation_session_strikes": {
      "type": "integer",
      "description": "Advisory/session continuity: strike count."
    },
    "escalation_session_idle_turns": {
      "type": "integer",
      "description": "Advisory/session continuity: idle turns."
    },
    "uchi_soto_profiles": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Advisory: per-agent interaction profiles (trust/tone continuity)."
    },
    "migratory_body": {
      "type": "object",
      "description": "Block 4.3 — Migratory handle (hardware_profile, hardware_id, capabilities).",
      "required": ["energy", "active_nodes", "sensors_ok", "description", "hardware_profile", "hardware_id", "capabilities"],
      "properties": {
          "energy": { "type": "number" },
          "active_nodes": { "type": "integer" },
          "sensors_ok": { "type": "boolean" },
          "description": { "type": "string" },
          "hardware_profile": { "type": "string" },
          "hardware_id": { "type": "string" },
          "capabilities": {
              "type": "array",
              "items": { "type": "string" }
          }
      }
    }
  }
}
