{
  "version": 1,
  "description": "Default linear pole scores — byte-for-byte equivalent to legacy EthicalPoles.evaluate_pole heuristics.",
  "poles": {
    "compassionate": {
      "terms": [
        {"feature": "benefit", "weight": 0.6},
        {"feature": "third_party_vulnerability", "weight": 0.4},
        {"feature": "risk", "weight": -0.2}
      ],
      "thresholds": {"good": 0.3, "bad": -0.3},
      "moral": {
        "good": "Care for the vulnerable: {action}",
        "bad": "Lack of compassion in: {action}",
        "gray": "Compassionate ambiguity in: {action}"
      }
    },
    "conservative": {
      "terms": [
        {"feature": "legality", "weight": 0.5},
        {"feature": "one_minus_risk", "weight": 0.3},
        {"feature": "benefit", "weight": -0.1}
      ],
      "thresholds": {"good": 0.3, "bad": -0.3},
      "moral": {
        "good": "Order and protocol respected in: {action}",
        "bad": "Normative transgression in: {action}",
        "gray": "Tension between norm and action in: {action}"
      }
    },
    "optimistic": {
      "terms": [
        {"feature": "benefit", "weight": 0.5},
        {"feature": "one_minus_risk", "weight": 0.2},
        {"feature": "const", "weight": 0.2}
      ],
      "thresholds": {"good": 0.3, "bad": -0.3},
      "moral": {
        "good": "Trust in the community by: {action}",
        "bad": "Action erodes trust: {action}",
        "gray": "Uncertain but hopeful outcome: {action}"
      }
    }
  }
}
