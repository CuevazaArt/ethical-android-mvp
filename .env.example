# Copy to .env and fill in locally — never commit .env or real secrets.
#
# KERNEL_ENV_VALIDATION — unset in a production shell defaults to strict (fail fast on invalid KERNEL_* combos).
# Lab nominal profiles (ETHOS_RUNTIME_PROFILE) set warn when merging; pytest sets warn via conftest — see KERNEL_ENV_POLICY.md.
# KERNEL_ENV_VALIDATION=warn
# KERNEL_ENV_VALIDATION=strict
# KERNEL_ENV_VALIDATION=off
# Docker production-ish overlay (docker-compose.prodish.yml) loads this file into the app service — keep secrets here, not in the image.
# See docs/proposals/KERNEL_ENV_POLICY.md for the full KERNEL_* catalog.
# One-shot operator bundle (fills only unset/empty keys): names in src/runtime_profiles.py
# ETHOS_RUNTIME_PROFILE=lan_operational
# ETHOS_RUNTIME_PROFILE=situated_v8_lan_demo
# Fernet key example (generate with cryptography.fernet.Fernet.generate_key()):
# KERNEL_CHECKPOINT_FERNET_KEY=

CHAT_HOST=127.0.0.1
CHAT_PORT=8765
# Optional: max async wait per WebSocket turn (sync LLM may still run until OLLAMA_TIMEOUT)
# KERNEL_CHAT_TURN_TIMEOUT=180
# Optional: dedicated thread pool for chat turns (0 = Starlette/anyio default)
# KERNEL_CHAT_THREADPOOL_WORKERS=16
# Default on: build WebSocket JSON (incl. optional KERNEL_LLM_MONOLOGUE) off the event loop
# KERNEL_CHAT_JSON_OFFLOAD=1
LLM_MODE=local
# LLM_MODE=ollama
# USE_LOCAL_LLM=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b
# ANTHROPIC_API_KEY=

# KERNEL_API_DOCS=0
# KERNEL_METRICS=0
# Docker prodish overlay: Compose substitutes ${KERNEL_METRICS:-0} / ${KERNEL_API_DOCS:-0} from this file — set KERNEL_METRICS=1 to expose /metrics without merging docker-compose.metrics.yml
# KERNEL_LOG_JSON=0
# KERNEL_LOG_DECISION_EVENTS=1
# When KERNEL_LOG_JSON=1, emit one JSON line per EthicalKernel.process (machine-readable; disable with 0)
# KERNEL_LOG_LEVEL=INFO
# KERNEL_CHECKPOINT_PATH=
# KERNEL_CHECKPOINT_FERNET_KEY=
# Phase 4 nomadic handshake — Ed25519 key seed (32 bytes as base64 or 64 hex chars); public key on receiving device
# KERNEL_NOMADIC_ED25519_PRIVATE_KEY=
# KERNEL_NOMADIC_ED25519_PUBLIC_KEY=
# Nomad LAN WebSocket `/ws/nomad` — max decoded bytes per vision frame / audio chunk (see docs/ENV_VAR_CATALOG.md §11)
# KERNEL_NOMAD_MAX_VISION_FRAME_BYTES=5242880
# KERNEL_NOMAD_MAX_AUDIO_PCM_BYTES=1048576
# Append-only JSONL audit chain for MalAbs / kernel blocks (see docs/AUDIT_TRAIL_AND_REPRODUCIBILITY.md)
# KERNEL_AUDIT_CHAIN_PATH=
# KERNEL_AUDIT_HMAC_SECRET=
# KERNEL_AUDIT_INCLUDE_REASON_HASH=1
# Operator feedback → Psi Sleep mixture nudge (see docs/proposals/PROPOSAL_ETHICAL_CORE_LOGIC_EVOLUTION.md)
# KERNEL_FEEDBACK_CALIBRATION=0
# KERNEL_PSI_SLEEP_UPDATE_MIXTURE=0
# KERNEL_FEEDBACK_CALIBRATION_MIN_SAMPLES=2
# KERNEL_PSI_SLEEP_FEEDBACK_BLEND=0.12
# Legacy affine-only three valuations (cosmetic ordering = base ordering); default off — see weighted_ethics_scorer.py
# BI-P0-01 — BayesianInferenceEngine mode: disabled | telemetry_only | posterior_assisted | posterior_driven
# KERNEL_BAYESIAN_MODE=disabled
# KERNEL_BAYESIAN_LEGACY_AFFINE_VALUATIONS=0
# ADR 0012 — Plackett-Luce softmax likelihood + importance sampling (explicit triples only; default heuristic updater)
# KERNEL_FEEDBACK_LIKELIHOOD=heuristic
# KERNEL_FEEDBACK_LIKELIHOOD=softmax_is
# KERNEL_FEEDBACK_SOFTMAX_BETA=10.0
# ADR 0012 Level 3 — per-context_type mixture posteriors (requires KERNEL_BAYESIAN_FEEDBACK + feedback JSON with context_type)
# KERNEL_BAYESIAN_CONTEXT_LEVEL3=0
# KERNEL_ACTIVE_CONTEXT_TYPE=
# KERNEL_CONTEXT_SCENARIO_MAP_JSON={"1":"bucket_a","2":"bucket_b"}
# KERNEL_CONTEXT_KEYWORDS_JSON={"medical":["emergency"],"everyday":["walk"]}
# Semantic MalAbs (defaults: gate + hash fallback ON when unset — see semantic_chat_gate.py)
# KERNEL_SEMANTIC_CHAT_GATE=1
# KERNEL_SEMANTIC_EMBED_HASH_FALLBACK=1
# Lexical hardening (leet / bidi strip for substring MalAbs)
# KERNEL_MALABS_LEET_FOLD=1
# KERNEL_MALABS_STRIP_BIDI=1
# LLM perception: blend toward cautious priors when coercion report distrusts the payload (src/modules/perception_schema.py)
# KERNEL_PERCEPTION_FAILSAFE=1
# KERNEL_PERCEPTION_FAILSAFE_BLEND=0.42
# Optional: parallelize independent perception-side enrichments (light-risk/premise/reality + sensor overlays)
# KERNEL_PERCEPTION_PARALLEL=1
# Optional: workers when parallel mode is on (default: hardware-aware cap)
# KERNEL_PERCEPTION_PARALLEL_WORKERS=4
# Tri-lobe PerceptiveLobe (kernel_lobes): optional async HTTP GET probe — unset = no outbound request
# KERNEL_PERCEPTIVE_LOBE_PROBE_URL=http://127.0.0.1:11434/health
# Temporal directive (advisory): battery horizon and synchronization posture for strategy/planning
# KERNEL_TEMPORAL_BATTERY_MINUTES_AT_FULL=360
# KERNEL_TEMPORAL_BATTERY_LOW_HORIZON_MIN=30
# KERNEL_TEMPORAL_LAN_SYNC=1
# KERNEL_TEMPORAL_DAO_SYNC=1
# When the LLM perception path fails: template_local (default) | fast_fail | session_banner — see PROPOSAL_PERCEPTION_BACKEND_DEGRADATION_POLICY.md
# KERNEL_PERCEPTION_BACKEND_POLICY=template_local
# When communicate/narrate LLM fails: template_local (default) | canned_safe — see PROPOSAL_LLM_VERBAL_DEGRADATION_POLICY.md
# KERNEL_VERBAL_LLM_BACKEND_POLICY=template_local
# Optional: one knob for both communicate + narrate when per-touchpoint keys below are unset
# KERNEL_LLM_VERBAL_FAMILY_POLICY=template_local
# Per-touchpoint overrides (highest precedence): PROPOSAL_LLM_TOUCHPOINT_DEGRADATION_MATRIX.md
# KERNEL_LLM_TP_PERCEPTION_POLICY=template_local
# KERNEL_LLM_TP_COMMUNICATE_POLICY=template_local
# KERNEL_LLM_TP_NARRATE_POLICY=template_local
# Monologue enrich (requires KERNEL_LLM_MONOLOGUE=1): passthrough (default) | annotate_degraded
# KERNEL_LLM_TP_MONOLOGUE_POLICY=passthrough
# KERNEL_LLM_MONOLOGUE_BACKEND_POLICY=passthrough
# Situated sensor ingress: optional strict validation of merged sensor JSON (chat WebSocket `sensor` + fixture + preset)
# KERNEL_SENSOR_INPUT_STRICT=1
# KERNEL_MORAL_HUB_PUBLIC=0
#
# --- ADR 0017 — Field test / smartphone sensor relay (LAN lab only; default off) ---
# See docs/adr/0017-smartphone-sensor-relay-bridge.md and docs/proposals/PROPOSAL_FIELD_TEST_PLAN.md
# KERNEL_FIELD_CONTROL=0
# KERNEL_FIELD_PAIRING_TOKEN=
# KERNEL_FIELD_SENSOR_HZ=2
# KERNEL_FIELD_ALLOW_WAN=0
