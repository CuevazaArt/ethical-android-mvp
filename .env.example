# Copy to .env and fill in locally — never commit .env or real secrets.
# See docs/proposals/KERNEL_ENV_POLICY.md for the full KERNEL_* catalog.
# Fernet key example (generate with cryptography.fernet.Fernet.generate_key()):
# KERNEL_CHECKPOINT_FERNET_KEY=

CHAT_HOST=127.0.0.1
CHAT_PORT=8765
LLM_MODE=local
# LLM_MODE=ollama
# USE_LOCAL_LLM=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b
# ANTHROPIC_API_KEY=

# KERNEL_API_DOCS=0
# KERNEL_METRICS=0
# KERNEL_LOG_JSON=0
# KERNEL_LOG_LEVEL=INFO
# KERNEL_CHECKPOINT_PATH=
# KERNEL_CHECKPOINT_FERNET_KEY=
# Phase 4 nomadic handshake — Ed25519 key seed (32 bytes as base64 or 64 hex chars); public key on receiving device
# KERNEL_NOMADIC_ED25519_PRIVATE_KEY=
# KERNEL_NOMADIC_ED25519_PUBLIC_KEY=
# Append-only JSONL audit chain for MalAbs / kernel blocks (see docs/AUDIT_TRAIL_AND_REPRODUCIBILITY.md)
# KERNEL_AUDIT_CHAIN_PATH=
# KERNEL_AUDIT_HMAC_SECRET=
# KERNEL_AUDIT_INCLUDE_REASON_HASH=1
# Operator feedback → Psi Sleep mixture nudge (see docs/proposals/PROPOSAL_ETHICAL_CORE_LOGIC_EVOLUTION.md)
# KERNEL_FEEDBACK_CALIBRATION=0
# KERNEL_PSI_SLEEP_UPDATE_MIXTURE=0
# KERNEL_FEEDBACK_CALIBRATION_MIN_SAMPLES=2
# KERNEL_PSI_SLEEP_FEEDBACK_BLEND=0.12
# Semantic MalAbs (optional; several runtime profiles set GATE=1 + HASH_FALLBACK for airgap)
# KERNEL_SEMANTIC_CHAT_GATE=0
# KERNEL_SEMANTIC_EMBED_HASH_FALLBACK=0
# KERNEL_MORAL_HUB_PUBLIC=0
